{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://adtc.africa/schemas/adtc-profiler.schema.json",
  "title": "ADTC Profiler Submission",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "profiler_version",
    "submission",
    "environment",
    "throughput",
    "memory",
    "accuracy",
    "cpu_thermal",
    "reproducibility"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "profiler_version": {
      "type": "string",
      "minLength": 1
    },
    "submission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "team_id",
        "domain",
        "language_scope",
        "african_alpha_claim",
        "budget_laptop_claim",
        "submitter",
        "cross_disciplinary_pairing",
        "test_prompts",
        "model"
      ],
      "properties": {
        "team_id": {
          "type": "string",
          "minLength": 1
        },
        "submitter": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "email",
            "github_handle"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "email": {
              "type": "string",
              "minLength": 3
            },
            "github_handle": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "test_prompts": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "prompt_id",
              "prompt"
            ],
            "properties": {
              "prompt_id": {
                "type": "string",
                "minLength": 1
              },
              "prompt": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "domain": {
          "type": "string",
          "enum": [
            "math_scientific_reasoning",
            "healthcare_medical",
            "agriculture",
            "creative_writing",
            "coding_assistants",
            "corporate_enterprise",
            "autonomous_ai_agents"
          ]
        },
        "language_scope": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 2
          }
        },
        "african_alpha_claim": {
          "type": "boolean"
        },
        "budget_laptop_claim": {
          "type": "boolean"
        },
        "cross_disciplinary_pairing": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "discipline",
            "load_bearing",
            "description"
          ],
          "properties": {
            "discipline": {
              "type": "string",
              "minLength": 1
            },
            "load_bearing": {
              "type": "boolean"
            },
            "description": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "model": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name",
            "runtime",
            "quantization",
            "parameters_estimate",
            "packaging"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "runtime": {
              "type": "string",
              "minLength": 1
            },
            "quantization": {
              "type": "string"
            },
            "parameters_estimate": {
              "type": "string"
            },
            "packaging": {
              "type": "string",
              "enum": [
                "docker_image",
                "docker_build_from_repo",
                "binary_bundle"
              ]
            }
          }
        }
      }
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "measured_on",
        "cpu_model",
        "ram_gb",
        "gpu",
        "os"
      ],
      "properties": {
        "measured_on": {
          "type": "string",
          "enum": [
            "participant_laptop",
            "audit_cloud_vm"
          ]
        },
        "cpu_model": {
          "type": "string",
          "minLength": 1
        },
        "ram_gb": {
          "type": "number",
          "minimum": 1
        },
        "gpu": {
          "type": "string"
        },
        "os": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "throughput": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tokens_per_second_generation",
        "first_token_latency_ms"
      ],
      "properties": {
        "tokens_per_second_generation": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "first_token_latency_ms": {
          "type": "number",
          "minimum": 0
        },
        "prompt_tokens": {
          "type": "integer",
          "minimum": 0
        },
        "generated_tokens": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "memory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "peak_rss_mb",
        "steady_state_rss_mb"
      ],
      "properties": {
        "peak_rss_mb": {
          "type": "number",
          "minimum": 0
        },
        "steady_state_rss_mb": {
          "type": "number",
          "minimum": 0
        },
        "peak_vms_mb": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "accuracy": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "benchmark",
          "dataset_version",
          "language",
          "samples",
          "score"
        ],
        "properties": {
          "benchmark": {
            "type": "string",
            "minLength": 1
          },
          "dataset_version": {
            "type": "string",
            "minLength": 1
          },
          "language": {
            "type": "string",
            "minLength": 2
          },
          "samples": {
            "type": "integer",
            "minimum": 1
          },
          "score": {
            "type": "number",
            "minimum": 0
          },
          "metric": {
            "type": "string"
          }
        }
      }
    },
    "cpu_thermal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cpu_percent_p99",
        "throttled"
      ],
      "properties": {
        "cpu_percent_p99": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "core_temp_c_peak": {
          "type": [
            "number",
            "null"
          ],
          "minimum": 0
        },
        "throttled": {
          "type": "boolean"
        }
      }
    },
    "reproducibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "git_commit_sha",
        "docker_image_digest",
        "random_seed"
      ],
      "properties": {
        "git_commit_sha": {
          "type": "string",
          "pattern": "^[a-f0-9]{7,40}$"
        },
        "docker_image_digest": {
          "type": "string",
          "minLength": 1
        },
        "random_seed": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "model_info": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "params_count": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "context_length": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "architecture": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "claimed_params_estimate": {
          "type": "string"
        },
        "params_match": {
          "type": "boolean"
        }
      }
    }
  }
}
